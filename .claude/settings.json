{
  "env": {
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "1"
  },
  "permissions": {
    "allow": [
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(npx prisma:*)"
    ],
    "deny": [
      "Bash(**/.env)",
      "Read(**/.env)",
      "Write(**/.env)"
    ]
  },
  "model": "opus",
  "alwaysThinkingEnabled": true
}