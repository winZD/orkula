generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  groves       Grove[]
  harvests     Harvest[]
  categories   Category[]
  transactions Transaction[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sessions Session[]
  harvests Harvest[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Grove {
  id        String   @id @default(cuid())
  name      String
  location  String?
  area      Float?
  treeCount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  varieties         GroveVariety[]
  harvests          Harvest[]
  groveApplications GroveApplication[]
}

model GroveVariety {
  id        String   @id @default(cuid())
  variety   String
  treeCount Int?
  createdAt DateTime @default(now())

  groveId String
  grove   Grove  @relation(fields: [groveId], references: [id], onDelete: Cascade)

  @@unique([groveId, variety])
}

model Harvest {
  id           String        @id @default(cuid())
  date         DateTime
  quantityKg   Float
  oilYieldLt   Float?
  oilYieldPct  Float?
  method       HarvestMethod @default(HAND)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  groveId String
  grove   Grove  @relation(fields: [groveId], references: [id], onDelete: Cascade)

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum HarvestMethod {
  HAND
  RAKE
  MECHANICAL_SHAKER
  VIBRATOR
  NET
}

enum TransactionType {
  EXPENSE
  INCOME
}

model Category {
  id        String          @id @default(cuid())
  name      String
  type      TransactionType
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([tenantId, name, type])
}

model Transaction {
  id            String          @id @default(cuid())
  amount        Float
  date          DateTime
  type          TransactionType
  description   String?
  totalQuantity Float?
  unit          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  groveApplications GroveApplication[]

  @@index([tenantId, date])
  @@index([tenantId, type])
}

model GroveApplication {
  id             String   @id @default(cuid())
  quantity       Float
  calculatedCost Float
  createdAt      DateTime @default(now())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  groveId String
  grove   Grove @relation(fields: [groveId], references: [id], onDelete: Cascade)

  @@unique([transactionId, groveId])
}
